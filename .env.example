# Zappy Evolution API Host
# Copy to .env only for local Docker Compose.
# Render variables must be configured in Render.
# Zeabur variables must be configured in Zeabur.
# REQUIRED means the value must be set before production deployment.
# OPTIONAL means the default below is safe for initial production unless you enable that feature.

########################################
# REQUIRED - Server
########################################
SERVER_NAME=zappy-evolution
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=

########################################
# REQUIRED - Authentication
########################################
AUTHENTICATION_API_KEY=
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

########################################
# REQUIRED - Database
########################################
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=
DATABASE_CONNECTION_CLIENT_NAME=zappy_evolution

########################################
# OPTIONAL - PgBouncer / Supavisor advanced mode
########################################
# Leave blank unless you intentionally deploy with DATABASE_PROVIDER=psql_bouncer.
# For Zeabur MVP validation, prefer Zeabur Postgres or Supabase Session Pooler
# with DATABASE_PROVIDER=postgresql.
DATABASE_BOUNCER_CONNECTION_URI=

########################################
# REQUIRED - Persistence
########################################
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=false
DATABASE_SAVE_MESSAGE_UPDATE=false
DATABASE_SAVE_DATA_CONTACTS=false
DATABASE_SAVE_DATA_CHATS=false
DATABASE_SAVE_DATA_LABELS=false
DATABASE_SAVE_DATA_HISTORIC=false
DATABASE_SAVE_IS_ON_WHATSAPP=false
DATABASE_SAVE_IS_ON_WHATSAPP_DAYS=7
DATABASE_DELETE_MESSAGE=false
DEL_INSTANCE=false

########################################
# REQUIRED - Cache
########################################
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

########################################
# REQUIRED - Browser access and logs
########################################
CORS_ORIGIN=
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true
LOG_LEVEL=ERROR,WARN,INFO,LOG
LOG_COLOR=false
LOG_BAILEYS=error
LANGUAGE=en

########################################
# REQUIRED - WhatsApp pairing display
########################################
CONFIG_SESSION_PHONE_CLIENT=Zappy
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=30
QRCODE_COLOR=#146c5f

########################################
# OPTIONAL - Local Docker Compose Postgres only
########################################
POSTGRES_DB=evolution
POSTGRES_USER=evolution
POSTGRES_PASSWORD=

########################################
# OPTIONAL - Disabled integrations
########################################
TELEMETRY_ENABLED=false
PROMETHEUS_METRICS=false
WEBSOCKET_ENABLED=false
WEBHOOK_GLOBAL_ENABLED=true
RABBITMQ_ENABLED=false
SQS_ENABLED=false
PUSHER_ENABLED=false
KAFKA_ENABLED=false
TYPEBOT_ENABLED=false
CHATWOOT_ENABLED=false
OPENAI_ENABLED=false
DIFY_ENABLED=false
EVOAI_ENABLED=false
S3_ENABLED=false

########################################
# OPTIONAL - Webhooks
########################################
WEBHOOK_GLOBAL_URL=https://api.zappy.rest/api/whatsapp/webhook
WEBHOOK_EVENTS_QRCODE_UPDATED=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=false
