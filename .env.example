# LoyaltyPilot Evolution API Host
# Copy to .env for local Docker Compose only.
# Render values must be configured in Render and never committed.

########################################
# REQUIRED - Server
########################################
SERVER_NAME=evolution-api-host
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=https://your-evolution-api-host.onrender.com

########################################
# REQUIRED - Authentication
########################################
# Required. Generate a long random value. Send it in the `apikey` request header.
AUTHENTICATION_API_KEY=replace-with-long-random-api-key
# Required. Keep false in production to avoid exposing instance inventory.
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

########################################
# REQUIRED - Database
########################################
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:change-me@postgres:5432/evolution?schema=evolution_api
DATABASE_CONNECTION_CLIENT_NAME=evolution_api_host

########################################
# REQUIRED - Persistence flags
########################################
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=false
DATABASE_SAVE_DATA_HISTORIC=false
DATABASE_SAVE_IS_ON_WHATSAPP=true
DATABASE_SAVE_IS_ON_WHATSAPP_DAYS=7
DATABASE_DELETE_MESSAGE=false

########################################
# REQUIRED - Cache
########################################
# Render deployment uses local cache by default to avoid a separate Redis service.
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

########################################
# REQUIRED - CORS and logs
########################################
CORS_ORIGIN=https://your-loyaltypilot-web-domain.vercel.app
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true
LOG_LEVEL=ERROR,WARN,INFO,LOG
LOG_COLOR=false
LOG_BAILEYS=error
LANGUAGE=en

########################################
# OPTIONAL - Local docker-compose Postgres
########################################
POSTGRES_DB=evolution
POSTGRES_USER=evolution
POSTGRES_PASSWORD=change-me

########################################
# OPTIONAL - Disable integrations by default
########################################
TELEMETRY_ENABLED=false
PROMETHEUS_METRICS=false
WEBSOCKET_ENABLED=false
WEBHOOK_GLOBAL_ENABLED=false
RABBITMQ_ENABLED=false
SQS_ENABLED=false
PUSHER_ENABLED=false
KAFKA_ENABLED=false
TYPEBOT_ENABLED=false
CHATWOOT_ENABLED=false
OPENAI_ENABLED=false
DIFY_ENABLED=false
EVOAI_ENABLED=false
S3_ENABLED=false

########################################
# OPTIONAL - Webhook integration
########################################
WEBHOOK_GLOBAL_URL=
WEBHOOK_EVENTS_QRCODE_UPDATED=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=true

########################################
# OPTIONAL - WhatsApp pairing display
########################################
CONFIG_SESSION_PHONE_CLIENT=LoyaltyPilot
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=30
QRCODE_COLOR=#146c5f

